vault_path = "/Volumes/SSD/Dropbox/obsidian/SecundBrain"
gravacoes_dir = "🎙️ Gravações"
audios_dir = "🎙️ Gravações/_audios"
staging_dir = "/Volumes/SSD/Gravacoes/staging"   # SSD externo (Mac com pouco disco)

whisper_model = "medium"     # usado só no fallback local
whisper_language = "pt"
# Whisper-GPU remoto (faster-whisper large-v3, API OpenAI-compat). Vazio = local.
whisper_endpoint = "https://avell-ai-server.tail99394e.ts.net:5050"

summarizer = "codex"         # codex | ollama
ollama_model = "llama3.1:8b"
codex_model = ""             # vazio = default do codex

min_duration_sec = 5.0

target_apps = ["zoom.us", "Microsoft Teams", "Discord", "Google Chrome", "Safari", "Arc"]
ignored_apps = []
