# Copie para ~/.config/voxlog/voxlog.toml e ajuste para a SUA máquina.

# Pasta do seu vault do Obsidian (onde as notas serão criadas)
vault_path = "~/Obsidian/MeuVault"
gravacoes_dir = "🎙️ Gravações"
audios_dir = "🎙️ Gravações/_audios"

# Onde os segmentos temporários ficam durante a gravação.
# Se o disco interno for pequeno, aponte para um SSD externo (ex: /Volumes/SSD/Gravacoes/staging)
staging_dir = "~/voxlog/staging"

# ===== Transcrição (Whisper) =====
# OPÇÃO A — LOCAL (grátis, roda no seu Mac; deixe whisper_endpoint vazio):
#   modelos: tiny < base < small < medium < large-v3 (mais qualidade = mais lento/pesado)
whisper_model = "medium"
whisper_language = "pt"        # "" = autodetect
# OPÇÃO B — WEB/REMOTO (mais qualidade, não carrega o Mac): aponte para um serviço
#   compatível com a API OpenAI (/v1/audio/transcriptions). Ex.: faster-whisper-server
#   próprio numa GPU, ou um provedor de mercado. Vazio = usa o local acima.
whisper_endpoint = ""          # ex.: "https://meu-servidor:5050"

# ===== Resumo (LLM) =====
# summarizer: "codex" (CLI da OpenAI, grátis com assinatura ChatGPT) | "ollama" (local)
summarizer = "codex"
codex_model = ""               # vazio = modelo padrão da sua conta
ollama_model = "llama3.1:8b"   # usado se summarizer = "ollama"

min_duration_sec = 5.0

# Apps cuja chamada dispara o popup de gravação
target_apps = ["zoom.us", "Microsoft Teams", "com.microsoft.teams2", "Discord", "Google Chrome", "Safari", "Arc"]
ignored_apps = []

# ===== Diarização (separar falantes em reuniões) =====
# provider: "elevenlabs" (STT dedicado, robusto, recomendado) | "whisperx" (serviço :5051, pesado na GPU)
# A chave do ElevenLabs vai em ~/.config/voxlog/elevenlabs.env (ELEVENLABS_API_KEY=...), NUNCA aqui.
elevenlabs_model = "scribe_v1"
[voice]
enabled = true
provider = "elevenlabs"
max_sec = 7200            # acima disso, pula diarização
# Pré-trim de silêncio (obrigatório): dead air faz Whisper/Gemini loopar e o ElevenLabs alucinar.
# Remover mata os dois problemas e corta ~metade do custo. Comprime a linha do tempo (timestamps = tempo de fala).
trim_silence = true
silence_db = "-35dB"      # limiar do que conta como silêncio
silence_min_sec = 2.0     # só remove silêncios >= isto
silence_keep = 0.3        # padding mantido em cada corte
# provider "whisperx" (legado): endpoint do serviço :5051
# diarize_endpoint = "http://localhost:5051"

# ===== Taxonomia (opcional, mas muda tudo) =====
# Sem isto o modelo classifica no chute: uma reunião sobre a fila de demandas de um
# CLIENTE que fala muito de "plugin" e "review" acaba etiquetada como produto interno.
# Liste as SUAS entidades e ele passa a usar exatamente estes nomes.
[taxonomia]
clientes = ["ClienteA", "ClienteB"]
produtos = ["MeuProduto", "MeuAgente"]

# Pistas: termos que denunciam a entidade quando o NOME dela não é dito em voz alta.
# O dono de um cliente raramente é citado nas calls dele — a conversa fala do produto,
# não do nome. Sem pista, o modelo chuta.
[taxonomia.pistas]
"ClienteA" = ["check-in", "APK", "fazenda"]
"MeuAgente" = ["CNAB", "borderô"]

# ===== Glossário (opcional) =====
# O transcritor não conhece o vocabulário da sua operação. Aqui você conserta na marra,
# antes do resumo: chave = como costuma sair errado, valor = a forma correta.
[glossario]
"CACI" = "ClienteA"
"Proteus" = "Protheus"
"Gira" = "Jira"
